# Server Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# Database
DATABASE_URL="file:./dev.db"

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# Admin Credentials (for seeding)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin1234

# Video Configuration
VIDEO_DEFAULT_EXPIRY_DAYS=90
VIDEO_MAX_RETRIES=3

# ALPAS Integration (for future use)
ALPAS_API_URL=https://alpas.example.com/api
ALPAS_API_KEY=your-alpas-api-key

# Logging
LOG_LEVEL=info
