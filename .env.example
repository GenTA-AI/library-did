# Backend Configuration
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# Database (if using)
# DATABASE_URL=postgresql://user:password@localhost:5432/smart_did

# JWT Configuration
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=3600

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Video Storage
STORAGE_TYPE=local
STORAGE_PATH=./storage/videos
# For cloud storage:
# STORAGE_TYPE=s3
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=
# AWS_S3_BUCKET=

# Veo3.1 API Configuration
VEO_API_KEY=your-veo-api-key
VEO_API_ENDPOINT=https://api.veo.example.com/v1

# Video Generation Settings
VIDEO_DEFAULT_EXPIRY_DAYS=90
VIDEO_MAX_RETRIES=3
VIDEO_SCENE_DURATION=8

# Worker Configuration
WORKER_CONCURRENCY=2

# ALPAS Integration (when available)
ALPAS_API_URL=
ALPAS_API_KEY=

# Frontend Configuration
REACT_APP_API_URL=http://localhost:3000/api
REACT_APP_ENABLE_NOTIFICATIONS=true

# Admin Default Credentials (Change in production!)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme123
